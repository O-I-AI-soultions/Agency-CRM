# Airtable
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appecLcxk0qS8mNGV

# Auth
ITAY_PASSWORD=choose_a_password
OMRI_PASSWORD=choose_a_password
AUTH_SECRET=a_long_random_string_min_32_chars

# Apify (for scrape trigger feature)
APIFY_API_TOKEN=your_apify_api_token

# Google OAuth (for Calendar, Gmail, Drive integration in Settings)
# Register at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Base URL (used for OAuth redirects — set to your Vercel deployment URL)
NEXT_PUBLIC_BASE_URL=https://your-vercel-app.vercel.app

# GitHub (for lead → site generation)
# PAT (classic or fine-grained) with `repo` scope / "Administration: write" +
# "Contents: write" on the O-I-AI-soultions org, with access to its template repos.
GITHUB_API_TOKEN=your_github_personal_access_token

# Vercel (for auto-deploy of generated client sites)
VERCEL_API_TOKEN=your_vercel_personal_access_token
